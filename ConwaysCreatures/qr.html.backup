<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8" name="viewport" content="width=device-width, initial-scale=1.0">
<title>QR Scanner</title>

<style>
body {
    margin: 0;
    background: black;
    color: white;
    font-family: Arial, sans-serif;
}

video {
    width: 100vw;
    height: 100vh;
    object-fit: cover;
}

#mainMenu {
    width: 100vw;
    height: 100vh;
    object-fit: cover;
}

#result {
    position: fixed;
    bottom: 0;
    width: 100%;
    background: rgba(0,0,0,0.8);
    padding: 20px;
    font-size: 22px;
    box-sizing: border-box;
    word-wrap: break-word;
}
</style>
</head>
<body>
<div id="mainMenu">
    <button onclick="scanQR()">カード追加 Add Card Adicionar tarjeta</button>
    <button onclick="alert('battle not implemented yet!');">バットルスタート Battle Start Comenzar Batalla</button>
    <div id="cards">
    </div>
</div>
<video id="video" autoplay playsinline></video>
<div id="result">Starting camera...</div>

<script>
var cardCount=0
function scanQR() {
    const mainMenuDIV = document.getElementById("mainMenu");
    const video = document.getElementById("video");
    const resultDiv = document.getElementById("result");
    mainMenuDIV.style.display = "none";
    if (!("BarcodeDetector" in window)) {
        //resultDiv.innerText = "BarcodeDetector not supported.";
        resultDiv.innerText = "PLEASE RUNT HIS ON AN MODERN ANDROID DEVICE.";
    } else {

        const barcodeDetector = new BarcodeDetector({ formats: ["qr_code"] });

        navigator.mediaDevices.getUserMedia({
            video: { facingMode: "environment" }
        })
        .then(stream => {
            video.srcObject = stream;

            video.onloadedmetadata = () => {
                video.play();
                resultDiv.innerText = "Scanning...";
                requestAnimationFrame(scanFrame);
            };
        })
        .catch(err => {
            resultDiv.innerText = "Camera error: " + err.message;
        });

        function scanFrame() {

            if (video.readyState >= 2) {

                barcodeDetector.detect(video)
                .then(barcodes => {
                    if (barcodes.length > 0) {
                        //resultDiv.innerText = "QR Result:\n" + barcodes[0].rawValue;
                        const cards = document.getElementById("cards");
                        var cardName=barcodes[0].rawValue;
                        cards.innerHTML=cards.innerHTML+"<div id='"+cardCount+"'>ID:"+cardCount+"Name:"+cardName+"<img src='images/cards/"+cardName+".png' height=100 width=70></div>"
                        cardCount++;
                        //resultDiv.style.display = "none";
                        //video.style.display = "none";
                        mainMenuDIV.style.display = "block";

                    } else {
                        requestAnimationFrame(scanFrame);
                    }
                })
                .catch(err => {
                    resultDiv.innerText = "Scan error: " + err.message;
                });

            } else {
                requestAnimationFrame(scanFrame);
            }
        }
    }
}
</script>

</body>
</html>